APP_ENV=production
DEBUG=false

DATABASE_URL=postgresql+asyncpg://companion:companion@db:5432/companion
DATABASE_URL_SYNC=postgresql+psycopg2://companion:companion@db:5432/companion

JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_MIN_LENGTH=8
# Comma-separated origins. Leave unset to allow none explicitly; in production
# set your deployed frontend/API origins here.
# CORS_ORIGINS=https://app.example.com
