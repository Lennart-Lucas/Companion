APP_ENV=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://companion:companion@db:5432/companion
DATABASE_URL_SYNC=postgresql+psycopg2://companion:companion@db:5432/companion

JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_MIN_LENGTH=8
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Async job worker (optional overrides)
# JOB_POLL_INTERVAL_SECONDS=5
# JOB_BATCH_SIZE=10
# JOB_MAX_RETRIES=3
# JOB_RETRY_BASE_SECONDS=60
# JOB_SUCCESS_RETENTION_SECONDS=3600
# JOB_LOCK_TIMEOUT_SECONDS=300
